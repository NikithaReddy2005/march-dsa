# two pointer apporach
class Solution:
    def removeDuplicates(self, nums: List[int]) -> int:
        n=len(nums)
        if not nums:
            return 0
        i =0
        for j in range(1,n):                                #T.C:O(N)
            if (nums[j] != nums[j-1]):                      #S.C:O(1)
                nums[i+1]=nums[j]
                i=i+1
        return i+1
here in the above problem I have used two pointer apporoach where i is place at 0th index and j is iterated from index 1 to  len(nums)
at i+1 index all the elements are sorted with no duplicates.
