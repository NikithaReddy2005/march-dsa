#### HASHMAP APPORACH
class Solution(object):
    def twoSum(self, nums, target):
        d={}
        for i in range(0,len(nums)):
            b = target -nums[i]                      #T.C=O(N)      ......Optimal solution
            if (b in d):                             #S.C=O(N)      ......As HASHMAP is used
                return[i,d[b]]
            else:
                d[nums[i]]=i
