#### BRUTE FROCE APPORACH
class Solution(object):
    def twoSum(self, nums, target):
        n = len(nums)                               #T.C: O(N^2)
        for i in range(0,n-1):                      # S.C:O(1)
            for j in range(i+1,n):
                if (nums[i]+nums[j] == target):
                    return[i,j]
