##### TWO POINTER APPROACH
class Solution(object):
    def twoSum(self, nums, target):
        nums.sort()
        n = len(nums)
        i=0                                         #T.C : O(N LogN)
        j=n-1                                       # S.C: O(1)
        while(i<=j):
            if (nums[i]+nums[j] > target):
                j=j-1
            elif (nums[i]+nums[j]== target):
                return[i,j]
            else:
                i = i+1
